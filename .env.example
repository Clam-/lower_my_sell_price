# Copy this file to .env and fill in Production or Sandbox values.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=
EBAY_REFRESH_TOKEN=

# Optional: the HTTPS callback URL configured as the eBay Auth Accepted URL.
# Defaults to https://<LETSENCRYPT_DOMAIN>/callback when omitted.
EBAY_OAUTH_ACCEPTED_URL=

# Optional: use a short-lived User access token instead of refresh flow.
EBAY_OAUTH_ACCESS_TOKEN=

# Optional: scope list used when getting or refreshing an OAuth token.
# Trading API OAuth calls do not use scopes; the login helper uses eBay's base scope by default.
EBAY_OAUTH_SCOPES=

# 0=US, 15=Australia, 3=UK
EBAY_SITE_ID=0

# production or sandbox
EBAY_ENV=production

EBAY_COMPAT_LEVEL=1455

# Let's Encrypt HTTP-01 config for the temporary certificate helper.
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=
LETSENCRYPT_AGREE_TOS=false

# Use staging first to verify DNS/port forwarding, then set false or pass --production.
LETSENCRYPT_STAGING=true
LETSENCRYPT_HTTP_HOST=0.0.0.0
LETSENCRYPT_HTTP_PORT=8081
LETSENCRYPT_CERT_ROOT=certs
LETSENCRYPT_KEY_BITS=2048
LETSENCRYPT_TIMEOUT=300
LETSENCRYPT_POLL_INTERVAL=2

# Optional: custom ACME directory URL. Leave blank for Let's Encrypt staging/production.
LETSENCRYPT_DIRECTORY_URL=
