# Copy this file to .env and fill in Production or Sandbox values.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=

# Optional: use a short-lived User access token instead of refresh flow.
EBAY_OAUTH_ACCESS_TOKEN=

# Optional: scope list used when refreshing the access token.
EBAY_OAUTH_SCOPES=

# 0=US, 15=Australia, 3=UK
EBAY_SITE_ID=0

# production or sandbox
EBAY_ENV=production

EBAY_COMPAT_LEVEL=1455
